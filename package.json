{
  "name": "audex-player",
  "productName": "Audex",
  "version": "1.1.0",
  "description": "Audex — minimal desktop music player",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.audex.player",
    "productName": "Audex",
    "copyright": "Copyright © 2026 Mikhail Sokov and Sergei",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "LICENSE",
      "package.json",
      ".puppeteerrc.cjs",
      "build/icon.png",
      "build/icon.svg",
      "chromium-bundle/**"
    ],
    "asarUnpack": [
      "chromium-bundle/**"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icons",
      "category": "AudioVideo;Audio;Player",
      "synopsis": "Minimal desktop music player",
      "description": "Audex is a minimal local music player built with Electron.",
      "maintainer": "Mikhail Sokov <mikhail.sokov2006@gmail.com>",
      "desktop": {
        "entry": {
          "StartupWMClass": "audex"
        }
      }
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.music",
      "identity": null
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "Mikhail Sokov <mikhail.sokov2006@gmail.com>",
  "contributors": [
    "Mikhail Sokov <mikhail.sokov2006@gmail.com>",
    "Sergei <sergeifed2015@gmail.com>"
  ],
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "music-metadata": "^11.12.3",
    "node-id3": "^0.2.9",
    "puppeteer": "^23.11.1"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  }
}
